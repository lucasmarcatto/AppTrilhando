<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F8F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caminhe com atenção"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹️ Parado"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FB8C00"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Card de passos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Passos"
                android:textColor="#666666"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvPassos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#2E7D32" />

            <TextView
                android:id="@+id/tvPassosInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aguardando sensor..."
                android:textSize="14sp"
                android:textColor="#888888" />

        </LinearLayout>

        <!-- Localização -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Localização"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1B5E20" />

            <TextView
                android:id="@+id/tvLocalizacao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lat: --, Lon: --"
                android:textSize="16sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnAtualizarLocalizacao"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Atualizar Localização"
            android:backgroundTint="#43A047"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- Iniciar e Parar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnIniciar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Iniciar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnParar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Parar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnTirarFoto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Tirar Foto"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnFinalizarCaminhada"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Finalizar e Salvar"
            android:backgroundTint="#FB8C00"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnVoltarHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textColor="#666666"
            android:background="@android:color/transparent" />

    </LinearLayout>

</ScrollView>