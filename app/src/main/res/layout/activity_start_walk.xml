<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚶 Iniciar Caminhada"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Status da caminhada -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹️ Parado"
            android:textSize="18sp"
            android:textColor="#666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Contador de passos -->
        <TextView
            android:id="@+id/tvPassos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Passos: 0"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvPassosInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aguardando sensor..."
            android:textSize="14sp"
            android:textColor="#888"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD"
            android:layout_marginVertical="16dp" />

        <!-- Localização -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Localização"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLocalizacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lat: --, Lon: --"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnAtualizarLocalizacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Atualizar Localização"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#2196F3"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD"
            android:layout_marginVertical="16dp" />

        <!-- Botões de ação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnIniciar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶️ Iniciar"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnParar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏹️ Parar"
                android:backgroundTint="#F44336"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnTirarFoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="📷 Tirar Foto"
            android:backgroundTint="#2196F3" />

        <Button
            android:id="@+id/btnGravarAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="🎤 Gravar Áudio"
            android:backgroundTint="#673AB7" />

        <Button
            android:id="@+id/btnFinalizarCaminhada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="✅ Finalizar e Salvar"
            android:backgroundTint="#FF9800"
            android:enabled="false" />

        <Button
            android:id="@+id/btnVoltarHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="← Voltar"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#666" />

    </LinearLayout>
</ScrollView>