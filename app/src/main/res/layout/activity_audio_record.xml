<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎤 Áudio da Caminhada"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pronto para gravar"
            android:textSize="16sp"
            android:textColor="#666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGravar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏺️ Gravar"
            android:backgroundTint="#F44336"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnParar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹️ Parar"
            android:backgroundTint="#9E9E9E"
            android:enabled="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnReproduzir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶️ Reproduzir"
            android:backgroundTint="#2196F3"
            android:enabled="false"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD"
            android:layout_marginVertical="8dp" />

        <!-- Reconhecimento de voz -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗣️ Descrição por voz"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Toque em Falar e descreva a caminhada"
            android:minLines="2"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnFalar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎙️ Falar"
            android:backgroundTint="#673AB7"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD"
            android:layout_marginVertical="8dp" />

        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="☁️ Salvar no Firebase"
            android:backgroundTint="#4CAF50"
            android:enabled="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Voltar"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#666" />

    </LinearLayout>
</ScrollView>
