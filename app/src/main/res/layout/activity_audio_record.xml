<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F8F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descrição por Voz"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Card da descrição -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descrição"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etDescricao"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Fale ou digite a descrição"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:minLines="4"
                android:padding="16dp"
                android:background="@drawable/bg_edittext" />

        </LinearLayout>

        <!-- Botão de voz -->
        <Button
            android:id="@+id/btnOuvir"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Falar descrição"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B1FA2"
            android:layout_marginBottom="12dp" />

        <!-- Botão salvar -->
        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Salvar descrição"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#43A047"
            android:enabled="false"
            android:layout_marginBottom="12dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatusAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginBottom="20dp" />

        <!-- Voltar -->
        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textColor="#666666"
            android:background="@android:color/transparent" />

    </LinearLayout>

</ScrollView>