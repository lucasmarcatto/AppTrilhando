<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F8F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Ícone -->
        <ImageView
            android:id="@+id/imgSuccess"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:src="@drawable/logo_trilhando" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caminhada Finalizada!"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_gravity="center"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Revise as informações antes de salvar."
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Estatísticas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumo da Caminhada"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1B5E20"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtPassos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Passos: 3842"
                android:textSize="16sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/txtTempo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tempo: 00:45:20"
                android:textSize="16sp"
                android:textColor="#333333"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/txtData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data: 25/05/2024"
                android:textSize="16sp"
                android:textColor="#333333"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Descrição -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descrição da caminhada"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtDescricao"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top"
                android:hint="Conte como foi sua caminhada... Fale ou digite a descrição"
                android:padding="16dp"
                android:background="@drawable/bg_edittext"
                android:inputType="textMultiLine"
                android:minLines="4" />

        </LinearLayout>

        <!-- Voz -->
        <Button
            android:id="@+id/btnSpeech"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Falar descrição"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B1FA2"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtSpeechInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="O texto reconhecido aparecerá acima."
            android:textSize="13sp"
            android:textColor="#777777"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Salvar -->
        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Salvar Registro"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="12dp" />

        <!-- Descartar -->
        <Button
            android:id="@+id/btnDescartar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Descartar"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D32F2F" />

    </LinearLayout>

</ScrollView>